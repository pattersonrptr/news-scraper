# =============================================================================
# Application
# =============================================================================
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production

# =============================================================================
# JWT / Auth
# =============================================================================
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Database
# =============================================================================
# SQLite (local dev, no Docker)
DATABASE_URL=sqlite+aiosqlite:///./news.db

# PostgreSQL (Docker / production)
# DATABASE_URL=postgresql+asyncpg://newsuser:newspass@localhost:5432/newsdb

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# AI Provider
# =============================================================================
# Options: gemini | ollama
AI_PROVIDER=gemini

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_FALLBACK=true   # fall back to ollama if gemini rate-limits

# =============================================================================
# Feed Collection
# =============================================================================
DEFAULT_FETCH_INTERVAL=60   # minutes

# =============================================================================
# Email / SMTP
# =============================================================================
# ---------------------------------------------------------------------------
# Option A — Mailhog (local dev, no credentials needed)
#   Start with: docker compose up mailhog
#   View sent emails at: http://localhost:8025
# ---------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false

# ---------------------------------------------------------------------------
# Option B — Gmail (production / staging)
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to https://myaccount.google.com/apppasswords and create an App Password
#      (select "Mail" + your device).  The generated 16-char password is SMTP_PASSWORD.
#   3. Uncomment the block below and comment out Option A above.
# ---------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_USE_TLS=true

# Alert recipient (email address that receives keyword alerts and daily digest)
ALERT_EMAIL=your-email@gmail.com

# Max alert emails per keyword per hour (rate limiting)
ALERT_RATE_LIMIT_PER_HOUR=1

# Daily digest send time (UTC, HH:MM)
DIGEST_TIME=08:00

# =============================================================================
# Celery
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json   # json | text
